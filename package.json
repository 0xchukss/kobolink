{
  "name": "kobolink",
  "version": "0.1.0",
  "description": "Autonomous tipping for Nigerian X creators, priced in Kobo and settled on Arc.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.node.json",
    "typecheck": "tsc --noEmit -p tsconfig.node.json",
    "test": "npm run build && node --test tests/*.test.mjs",
    "proof:create-wallets": "npm run build && node dist/proofs/create-wallets.js",
    "proof:arc-balance": "npm run build && node dist/proofs/arc-balance.js",
    "proof:arc-transfer": "npm run build && node dist/proofs/arc-transfer.js",
    "proof:x402-payment": "npm run build && node dist/proofs/x402-payment.js",
    "dev": "next dev",
    "ui:dev": "next dev",
    "ui:build": "next build",
    "proof:real-mode": "npm run build && node dist/proofs/real-mode-readiness.js",
    "proof:tip-listing": "npm run build && node dist/proof-tip-listing.js",
    "proof:create-listing": "npm run build && node dist/proof-create-listing.js",
    "proof:authorize-budget": "npm run build && node dist/proof-authorize-budget.js",
    "proof:bridge-checkout": "npm run build && node dist/proof-bridge-checkout.js",
    "proof:bridge-verify": "npm run build && node dist/proof-bridge-verify.js",
    "proof:bridge-payout": "npm run build && node dist/proof-bridge-payout.js",
    "proof:fund-gateway": "npm run build && node dist/proof-fund-gateway.js",
    "proof:listings": "npm run build && node dist/proof-listings.js",
    "proof:tip-status": "npm run build && node dist/proof-tip-status.js",
    "proof:agent": "npm run build && node dist/proof-agent.js",
    "proof:bridge-status": "npm run build && node dist/proof-bridge-status.js",
    "proof:full": "npm run build && node dist/proof-full.js",
    "proof:next": "npm run build && node dist/proof-next.js"
  },
  "keywords": [
    "arc",
    "x402",
    "usdc",
    "nanopayments",
    "nigeria",
    "creators",
    "agents"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@circle-fin/x402-batching": "^3.2.0",
    "@clerk/nextjs": "^7.5.12",
    "@gsap/react": "^2.1.2",
    "@neondatabase/serverless": "^1.1.0",
    "@x402/evm": "^2.17.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "gsap": "^3.15.0",
    "lottie-react": "^2.4.1",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.185.0",
    "viem": "^2.53.1"
  }
}
